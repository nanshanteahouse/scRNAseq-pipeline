# ────────────────────────────────────────────────────────────
# scRNAseq Pipeline — Environment Variables
# ────────────────────────────────────────────────────────────
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# 确保 .env 已被 .gitignore 排除，避免凭据泄露
# ────────────────────────────────────────────────────────────

# DeepSeek API Key — 从 https://platform.deepseek.com/api_keys 获取
# 当 config.py 中 api_key 留空时，ai_caller 会自动读取此环境变量
LLM_API_KEY=sk-your-key-here

# HDF5 文件锁定 — WSL 用户在 /mnt/ 路径下需设置为 FALSE
# export HDF5_USE_FILE_LOCKING=FALSE
